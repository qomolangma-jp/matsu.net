APP_NAME="松.net"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://matsu.localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=matsu_net
DB_USERNAME=matsu_user
DB_PASSWORD=matsu_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# メール設定（開発環境ではlog、本番環境ではsmtpなどを使用）
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@matsu.localhost"
MAIL_FROM_NAME="${APP_NAME}"

# LINE LIFF設定
LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
